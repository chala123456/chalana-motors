rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity test path
    match /test/connection {
      allow read: if true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for chalana_stats
    function isValidStats(data) {
      return data.size() <= 2 &&
             (!('netProfit' in data) || data.netProfit is number) &&
             (!('totalRevenue' in data) || data.totalRevenue is number);
    }

    match /chalana_stats/{statId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidStats(request.resource.data);
    }

    // Helper for inventory
    function isValidPart(data) {
      return data.keys().hasAll(['name', 'quantity']) &&
             data.name is string && data.name.size() <= 100 &&
             data.quantity is number &&
             (!('costPrice' in data) || data.costPrice is number) &&
             (!('userId' in data) || data.userId == request.auth.uid);
    }

    match /inventory/{partId} {
      allow read: if isSignedIn(); // Allow reading for all signed in users for now, or restrict if userId is present
      allow create: if isSignedIn() && isValidPart(request.resource.data);
      allow update: if isSignedIn() && isValidPart(request.resource.data) && (request.resource.data.userId == resource.data.userId || !('userId' in resource.data));
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
    }

    // Jobs
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Remote Scans
    match /remote_scans/{scanId} {
      allow read, write: if isSignedIn();
    }

    // Presence
    match /status/{statusId} {
      allow read, write: if isSignedIn();
    }
    
    // Service Presets
    match /service_presets/{presetId} {
      allow read, write: if isSignedIn();
    }
  }
}
