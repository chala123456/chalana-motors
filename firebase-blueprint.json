{
  "entities": {
    "Part": {
      "title": "Part",
      "description": "A spare part in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the part" },
        "costPrice": { "type": "number", "description": "Cost price of the part" },
        "quantity": { "type": "number", "description": "Current inventory level" },
        "lowStockThreshold": { "type": "number", "description": "Threshold for low stock warnings" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "When the part was last updated" }
      },
      "required": ["name", "costPrice", "quantity"]
    },
    "RepairJob": {
      "title": "Repair Job",
      "description": "A customer repair record",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "contactNumber": { "type": "string" },
        "vehicleNumber": { "type": "string" },
        "vehicleModel": { "type": "string" },
        "issue": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "ongoing", "completed"] },
        "repairFee": { "type": "number" },
        "partsUsed": {
          "type": "array",
          "items": { "$ref": "#/entities/UsedPart" }
        },
        "totalPartsCost": { "type": "number" },
        "profit": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status"]
    },
    "UsedPart": {
      "title": "Used Part",
      "description": "A part used in a repair",
      "type": "object",
      "properties": {
        "partId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "costAtTime": { "type": "number" }
      }
    },
    "DailySummary": {
      "title": "Daily Summary",
      "description": "Aggregated daily revenue and profit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "totalRevenue": { "type": "number" },
        "totalProfit": { "type": "number" },
        "jobCount": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "ServicePreset": {
      "title": "Service & Part Preset",
      "description": "Predefined services or parts and prices for repair jobs",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["service", "part"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "userId"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "contactNumber": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "vehicleNumbers": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["contactNumber", "userId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense record",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "amount", "date", "userId"]
    },
    "RemoteScan": {
      "title": "Remote Scan Session",
      "description": "Real-time bridge for mobile barcode scanning",
      "type": "object",
      "properties": {
        "barcode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "added", "error", "not_found"] },
        "partName": { "type": "string" },
        "userId": { "type": "string" },
        "quickAddData": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "price": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "updatedAt"]
    },
    "UserStatus": {
      "title": "User Presence Status",
      "description": "Tracks if the desktop receiver is active for remote scanning",
      "type": "object",
      "properties": {
        "remoteReceiverActive": { "type": "boolean" },
        "lastActive": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["userId"]
    },
    "GlobalStats": {
      "title": "Global Stats",
      "description": "System-wide financial metrics",
      "type": "object",
      "properties": {
        "netProfit": { "type": "number" },
        "totalRevenue": { "type": "number" }
      }
    }
  },
  "firestore": {
    "chalana_stats": {
      "schema": "GlobalStats",
      "description": "Aggregated system stats for the dashboard"
    },
    "inventory": {
      "schema": "Part",
      "description": "Inventory of spare parts"
    },
    "jobs": {
      "schema": "RepairJob",
      "description": "History and current repair jobs"
    },
    "daily_summaries": {
      "schema": "DailySummary",
      "description": "Aggregated daily business metrics"
    },
    "service_presets": {
      "schema": "ServicePreset",
      "description": "Standard service pricing templates"
    },
    "customers": {
      "schema": "Customer",
      "description": "Customer database"
    },
    "expenses": {
      "schema": "Expense",
      "description": "Business expense tracking"
    },
    "remote_scans": {
      "schema": "RemoteScan",
      "description": "Mobile scanning bridge"
    },
    "status": {
      "schema": "UserStatus",
      "description": "User presence and receiver state"
    }
  }
}
